{
	"name": "@schilderlabs/pitown",
	"version": "0.2.6",
	"type": "module",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		}
	},
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown",
		"lint": "eslint .",
		"test": "vitest run --passWithNoTests",
		"town:doctor": "tsx src/doctor.ts",
		"town:run": "tsx src/run.ts",
		"town:status": "tsx src/status.ts",
		"town:watch": "tsx src/watch.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@schilderlabs/pitown-core": "workspace:*",
		"@schilderlabs/pitown-package": "workspace:*"
	},
	"devDependencies": {
		"eslint": "9.39.3",
		"tsdown": "0.20.3",
		"tsx": "4.21.0",
		"typescript": "5.9.2",
		"vitest": "4.0.18"
	},
	"bin": {
		"pitown": "./dist/index.mjs"
	},
	"bugs": "https://github.com/RobSchilderr/pitown/issues",
	"description": "Globally installable CLI for Pi Town",
	"files": [
		"dist",
		"README.md"
	],
	"homepage": "https://github.com/RobSchilderr/pitown#readme",
	"keywords": [
		"automation",
		"cli",
		"orchestration",
		"pi-package",
		"pi-town",
		"pitown"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": "RobSchilderr/pitown.git"
}
